# Database
DATABASE_URL="postgresql://user:password@localhost:5432/catchmyaction?schema=public"

# Auth
NEXTAUTH_SECRET="change-me-to-a-random-string"
NEXTAUTH_URL="http://localhost:3000"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Stripe (optional — mock purchases work without these)
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# AWS S3 (optional — local storage used when not set)
# AWS_REGION="us-east-1"
# AWS_ACCESS_KEY_ID="your-access-key"
# AWS_SECRET_ACCESS_KEY="your-secret-key"
# S3_BUCKET_ORIGINALS="catchmyaction-originals"
# S3_BUCKET_PREVIEWS="catchmyaction-previews"

# Set to "true" to force local file storage even with AWS configured
# USE_LOCAL_STORAGE="true"
